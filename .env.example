DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/trackswift?sslmode=require"
JWT_SECRET="replace-with-at-least-32-random-characters"
JWT_EXPIRES_IN="8h"
PORT=4173
CLIENT_ORIGIN="http://localhost:4173"

# Used only by `npm run db:seed` to create the first administrator.
ADMIN_NAME="TrackSwift Admin"
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="replace-with-a-strong-password"
