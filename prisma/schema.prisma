generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ShipmentStage {
  SHIPMENT_CREATED
  PROCESSING_IN_ITALY
  PACKAGE_PICKED_UP
  DEPARTED_ORIGIN_FACILITY
  INTERNATIONAL_TRANSIT
  CUSTOMS_CLEARANCE
  ARRIVED_IN_UNITED_STATES
  LOCAL_DISTRIBUTION_FACILITY
  OUT_FOR_DELIVERY
  DELIVERED
}

model Admin {
  id               String          @id @default(cuid())
  name             String
  email            String          @unique
  passwordHash     String
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  createdShipments Shipment[]      @relation("ShipmentCreator")
  progressEvents   ProgressEvent[] @relation("ProgressUpdatedBy")

  @@index([createdAt])
}

model Shipment {
  id                 String        @id @default(cuid())
  trackingId         String        @unique
  customerName       String
  customerEmail      String
  createdById        String
  description        String
  originCity         String
  originCountry      String        @default("Italy")
  destinationCity    String
  destinationCountry String       @default("United States")
  weightKg           Decimal?      @db.Decimal(10, 2)
  dimensions         String?
  currentStage       ShipmentStage @default(SHIPMENT_CREATED)
  currentLocation    String?
  estimatedDelivery DateTime?
  carrierNotes       String?
  deliveredAt        DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  createdBy          Admin         @relation("ShipmentCreator", fields: [createdById], references: [id], onDelete: Restrict)
  progressEvents     ProgressEvent[]

  @@index([customerEmail, updatedAt])
  @@index([createdById, createdAt])
  @@index([currentStage, updatedAt])
}

model ProgressEvent {
  id              String        @id @default(cuid())
  shipmentId      String
  stage           ShipmentStage
  location        String?
  notes           String?
  eventTime       DateTime      @default(now())
  customerVisible Boolean       @default(true)
  createdById     String
  createdAt       DateTime      @default(now())
  shipment        Shipment      @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  createdBy       Admin         @relation("ProgressUpdatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([shipmentId, eventTime])
  @@index([createdById, createdAt])
}
